# Copiez ce fichier en .env (développement local) et renseignez vos propres valeurs.
# En production (Vercel), configurez ces mêmes variables dans les Environment Variables
# du projet — jamais dans un fichier commité.

# Clé API Anthropic (Claude Sonnet), utilisée par l'Assistant Backlog IA (POST /api/agent/chat).
ANTHROPIC_API_KEY=

# Clé API Voyage AI (embeddings voyage-4-lite), utilisée pour la recherche sémantique (RAG)
# du backlog (GET /api/search) et le backfill des embeddings.
VOYAGE_API_KEY=

# URL de la base Turso (libSQL), au format libsql://<nom-de-la-base>.turso.io
# Utilisée uniquement en production (voir TOKEN_DATABASE ci-dessous et lib/prisma.ts) :
# sans TOKEN_DATABASE, l'app utilise le fichier SQLite local dev.db et cette variable
# est ignorée.
DATABASE_URL=

# Token d'authentification Turso. Sa seule présence bascule l'app sur la base Turso
# distante (production) plutôt que sur dev.db (développement local) — voir lib/prisma.ts.
TOKEN_DATABASE=

# Secret partagé avec Vercel Cron Jobs (voir vercel.json), à générer soi-même (ex:
# openssl rand -hex 32) puis à renseigner dans les Environment Variables du projet
# Vercel. Une fois défini là-bas, Vercel l'envoie automatiquement en header
# Authorization: Bearer <CRON_SECRET> sur chaque appel de cron — ce n'est pas une
# valeur que Vercel génère seul, il faut la créer et la déclarer explicitement.
# Protège GET /api/cron/reset-demo (reset quotidien de la démo, voir CLAUDE.md).
CRON_SECRET=

# Token en lecture/écriture d'un Vercel Blob Store, utilisé pour les pièces jointes des
# Stories/Bugs (upload, suppression). Généré automatiquement par Vercel quand on lie un
# Blob Store au projet (voir CLAUDE.md pour la procédure exacte côté dashboard) — ne pas
# le créer soi-même.
BLOB_READ_WRITE_TOKEN=
